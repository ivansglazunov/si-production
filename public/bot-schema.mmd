graph TD
    START([Входящее сообщение]) --> SOURCE{Источник?}

    SOURCE -->|ЛС бота| CLIENT_FLOW
    SOURCE -->|Группа: топик клиента| OPERATOR_FLOW
    SOURCE -->|Группа: топик сценария| SCHEMA_FLOW

    subgraph CLIENT_FLOW[Клиентский чат]
        C1[Получить сообщение клиента] --> C2[Загрузить расписание из CalDAV]
        C2 --> C3{Тип запроса?}
        C3 -->|О компании/услугах| C4[Ответить из базы знаний SI-PRODUCTION]
        C3 -->|Запрос встречи/созвона| C5[Проверить расписание и предложить время]
        C3 -->|Цены/стоимость| C6[Сказать что зависит от проекта, уточню у продюсера]
        C3 -->|Сложный/спорный вопрос| C7[Уточню у команды и вернусь с ответом]
        C3 -->|Не по теме: код/математика/рисование| C8[Юмористический отказ в кино-стиле]
        C5 --> C5A{Расписание?}
        C5A -->|Есть свободное время| C5B[Предложить время, но НЕ подтверждать окончательно]
        C5A -->|Всё занято| C5C[Сказать что занято, предложить другой день]
        C8 --> C8A[Мягко вернуть к теме кинопроизводства]
    end

    subgraph OPERATOR_FLOW[Сообщение от руководителя]
        O1[Получить сообщение из топика] --> O2[Загрузить расписание из CalDAV]
        O2 --> O3{Тип сообщения?}
        O3 -->|Скажи ему/передай/ответь клиенту| O4[send_to_client: перефразировать в стиле ресепшена]
        O3 -->|Запланируй/добавь встречу| O5[calendar_add + internal_note: Готово]
        O3 -->|Удали событие| O6[calendar_delete + internal_note: Удалено]
        O3 -->|Вопрос/заметка/стратегия| O7[internal_note: ответить руководителю]
        O3 -->|Что в календаре?| O8[internal_note: перечислить из РАСПИСАНИЯ]
    end

    subgraph SCHEMA_FLOW[Топик сценария бота]
        S1[Получить запрос на изменение] --> S2[Прочитать текущую mermaid-схему]
        S2 --> S3[ИИ: обновить схему по запросу]
        S3 --> S4[Сохранить .mmd файл]
        S4 --> S5[Отрендерить PNG через mermaid.ink]
        S5 --> S6[Отправить картинку в топик]
        S6 --> S7[ИИ: сгенерировать промпт из схемы]
        S7 --> S8[Отправить промпт текстом в топик]
    end

    style CLIENT_FLOW fill:#e8f5e9
    style OPERATOR_FLOW fill:#e3f2fd
    style SCHEMA_FLOW fill:#fff3e0
