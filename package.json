{
  "name": "si_production",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "build:filmography": "node scripts/convert_filmography.js",
    "download:posters": "node scripts/download_posters.js",
    "embed:lenta-images": "node scripts/embed_lenta_images.js",
    "service:install": "sudo cp scripts/si-production.service /etc/systemd/system/ && sudo systemctl daemon-reload && sudo systemctl enable si-production.service",
    "service:uninstall": "sudo systemctl stop si-production.service && sudo systemctl disable si-production.service && sudo rm /etc/systemd/system/si-production.service && sudo systemctl daemon-reload",
    "service:start": "sudo systemctl start si-production.service",
    "service:stop": "sudo systemctl stop si-production.service",
    "service:restart": "sudo systemctl restart si-production.service",
    "service:status": "sudo systemctl status si-production.service"
  },
  "dependencies": {
    "@headlessui/react": "^2.1.0",
    "dotenv": "^17.2.4",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "framer-motion": "^11.11.0",
    "next": "^16.1.1",
    "papaparse": "^5.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.6.0",
    "telegraf": "^4.16.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "autoprefixer": "^10.4.22",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "postcss": "^8.5.6",
    "sharp": "^0.33.0",
    "tailwindcss": "^4.1.17"
  }
}
